# Server
PORT=3000
# Bind address: 0.0.0.0 = accept connections from anywhere, 127.0.0.1 = localhost only
HOST=0.0.0.0
NODE_ENV=development

# CORS (comma-separated list of allowed origins)
# Add your remote frontend URL here, e.g.:
# CORS_ORIGIN=http://localhost:5173,http://192.168.1.42:5173,https://my-domain.com
CORS_ORIGIN=http://localhost:5173

# Database
DATABASE_URL="file:./dev.db"

# Auth — replace with long random strings in production
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=change-me-to-a-long-random-string
JWT_REFRESH_SECRET=change-me-to-another-long-random-string
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_DAYS=30

# start.gg integration
# Get a personal access token from https://start.gg/admin/profile/developer
STARTGG_API_TOKEN=

# Rate limiting / proxy
# Set TRUST_PROXY=false if the backend is NOT behind a reverse proxy
# TRUST_PROXY=false
