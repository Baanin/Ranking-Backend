// Prisma schema file — https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Core domain: Games, Seasons, Tournaments, Players, Participations
// ---------------------------------------------------------------------------

model Game {
  id         String   @id @default(cuid())
  name       String   @unique            // "Street Fighter 6"
  slug       String   @unique            // "sf6"
  startggId  Int?     @unique            // start.gg videogame ID (for auto-matching on import)
  iconColor  String   @default("from-red-500 to-orange-500")
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  tournaments Tournament[]
  seasons     Season[]

  @@index([isActive])
}

model Season {
  id         String   @id @default(cuid())
  name       String                       // "SF6 Season 2025", "Tekken Summer League"
  gameId     String
  game       Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)
  startDate  DateTime
  endDate    DateTime
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  tournaments Tournament[]

  @@unique([gameId, name])
  @@index([gameId, isActive])
  @@index([startDate, endDate])
}

model Tournament {
  id             String    @id @default(cuid())
  name           String
  date           DateTime
  location       String
  numEntrants    Int       @default(0)
  status         String    @default("upcoming") // upcoming | ongoing | completed
  prizePool      String?

  // start.gg link (nullable: some tournaments may be legacy / manual)
  startggSlug    String?   @unique             // ex: "tournament/genesis-9/event/ultimate-singles"
  startggEventId Int?      @unique
  lastSyncedAt   DateTime?

  gameId         String
  game           Game      @relation(fields: [gameId], references: [id])
  seasonId       String
  season         Season    @relation(fields: [seasonId], references: [id])

  winnerId       String?
  winner         Player?   @relation("TournamentWinner", fields: [winnerId], references: [id])

  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  entries        Participation[]

  @@index([gameId, seasonId])
  @@index([date])
  @@index([status])
}

model Player {
  id            String    @id @default(cuid())
  tag           String                          // gamertag / prefix
  name          String?                         // real name (optional)
  country       String                          // ISO 3166-1 alpha-2
  avatarColor   String    @default("from-red-500 to-orange-500")

  // start.gg identity
  startggUserId Int?      @unique               // numeric user ID
  startggSlug   String?   @unique               // "user/xxxxxxxx"

  // Support future dedup / merging
  mergedIntoId  String?
  mergedInto    Player?   @relation("PlayerMerge", fields: [mergedIntoId], references: [id])
  mergedFrom    Player[]  @relation("PlayerMerge")

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  participations  Participation[]
  wonTournaments  Tournament[]    @relation("TournamentWinner")

  @@unique([tag, country])
  @@index([tag])
}

model Participation {
  id           String     @id @default(cuid())
  tournamentId String
  playerId     String
  placement    Int
  pointsEarned Int        @default(0)

  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  player       Player     @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([tournamentId, playerId])
  @@index([playerId])
  @@index([tournamentId, placement])
}

// ---------------------------------------------------------------------------
// Admin / auth / audit (unchanged from previous steps)
// ---------------------------------------------------------------------------

model AdminUser {
  id            String         @id @default(cuid())
  email         String         @unique
  passwordHash  String
  name          String
  role          String         @default("ADMIN")
  permissions   String         @default("")
  isActive      Boolean        @default(true)
  lastLoginAt   DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  refreshTokens RefreshToken[]
}

model RefreshToken {
  id         String     @id @default(cuid())
  tokenHash  String     @unique
  userId     String
  user       AdminUser  @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt  DateTime
  revokedAt  DateTime?
  userAgent  String?
  createdAt  DateTime   @default(now())

  @@index([userId])
}

model AuditLog {
  id          String   @id @default(cuid())
  action      String
  entity      String?
  entityId    String?
  actorId     String?
  actorEmail  String?
  ipAddress   String?
  userAgent   String?
  metadata    String?
  createdAt   DateTime @default(now())

  @@index([createdAt])
  @@index([actorId])
  @@index([action])
  @@index([entity, entityId])
}
