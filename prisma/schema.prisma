// Prisma schema file — https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Player {
  id                 String              @id @default(cuid())
  tag                String              @unique
  name               String
  country            String
  mainGame           String
  character          String
  avatarColor        String              @default("from-red-500 to-orange-500")
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  participations     Participation[]
  wonTournaments     Tournament[]        @relation("TournamentWinner")
}

model Tournament {
  id             String          @id @default(cuid())
  name           String
  game           String
  date           DateTime
  location       String
  participants   Int             @default(0)
  status         String          @default("upcoming") // upcoming | ongoing | completed
  prizePool      String?
  winnerId       String?
  winner         Player?         @relation("TournamentWinner", fields: [winnerId], references: [id])
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  entries        Participation[]
}

model AdminUser {
  id            String         @id @default(cuid())
  email         String         @unique
  passwordHash  String
  name          String
  role          String         @default("ADMIN") // ADMIN | MODERATOR | ...
  permissions   String         @default("") // CSV of permission codes
  isActive      Boolean        @default(true)
  lastLoginAt   DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  refreshTokens RefreshToken[]
}

model RefreshToken {
  id         String     @id @default(cuid())
  tokenHash  String     @unique
  userId     String
  user       AdminUser  @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt  DateTime
  revokedAt  DateTime?
  userAgent  String?
  createdAt  DateTime   @default(now())

  @@index([userId])
}

model AuditLog {
  id          String   @id @default(cuid())
  action      String   // e.g. AUTH_LOGIN_SUCCESS, ADMIN_USER_CREATE, TOURNAMENT_DELETE
  entity      String?  // e.g. AdminUser, Tournament, Player
  entityId    String?
  actorId     String?  // AdminUser.id — null for anonymous (failed login)
  actorEmail  String?  // snapshot, survives admin deletion
  ipAddress   String?
  userAgent   String?
  metadata    String?  // JSON-encoded additional context
  createdAt   DateTime @default(now())

  @@index([createdAt])
  @@index([actorId])
  @@index([action])
  @@index([entity, entityId])
}

model Participation {
  id           String     @id @default(cuid())
  tournamentId String
  playerId     String
  placement    Int
  pointsEarned Int        @default(0)

  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  player       Player     @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([tournamentId, playerId])
  @@index([playerId])
}
